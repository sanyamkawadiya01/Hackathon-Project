datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String             @id @default(uuid())
  githubId     String?            @unique
  username     String             @unique
  email        String?            @unique
  displayName  String?
  name         String?
  avatarUrl    String?
  bio          String?
  followers    Int                @default(0)
  following    Int                @default(0)
  publicRepos  Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  
  oauthAccounts    OAuthAccount[]
  repositories     Repository[]
  contributions    Contribution[]
  skills           UserSkill[]
  achievements     UserAchievement[]
  ledgerEntries    ProofLedger[]
  metrics          DeveloperMetrics?

  @@map("users")
}

model OAuthAccount {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String    // 'github'
  providerUserId String
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  @@map("oauth_accounts")
}

model Repository {
  id              String         @id @default(uuid())
  repositoryId    String?        @unique
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubRepoId    BigInt?        @unique
  name            String
  fullName        String
  description     String?
  primaryLanguage String?
  language        String?
  starsCount      Int            @default(0)
  stars           Int            @default(0)
  forksCount      Int            @default(0)
  forks           Int            @default(0)
  topics          String[]       @default([])
  repoCreatedAt   DateTime?
  lastAnalyzedAt  DateTime?
  complexityScore Int            @default(0)
  isFork          Boolean        @default(false)
  createdAt       DateTime       @default(now())

  commits      Commit[]
  deployments  Deployment[]
  contributions Contribution[]
  contributionAnalysis ContributionAnalysis?

  @@map("repositories")
}

model Commit {
  id           String       @id @default(uuid())
  repositoryId String
  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  sha          String       @unique
  authorName   String
  authorEmail  String
  message      String
  linesAdded   Int          @default(0)
  linesDeleted Int          @default(0)
  commitDate   DateTime

  contribution Contribution?

  @@map("commits")
}

model Contribution {
  id                 String     @id @default(uuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId       String
  repository         Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  commitId           String     @unique
  commit             Commit     @relation(fields: [commitId], references: [id], onDelete: Cascade)
  linesContributed   Int
  contributionWeight Decimal    @db.Decimal(5, 2)
  analyzedDate       DateTime   @default(now())

  @@map("contributions")
}

model Deployment {
  id               String               @id @default(uuid())
  repositoryId     String
  repository       Repository           @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  url              String
  provider         String               @default("unknown")
  uptimePercentage Decimal              @default(100.00) @db.Decimal(5, 2)
  lastVerifiedAt   DateTime?
  createdAt        DateTime             @default(now())
  
  reports          VerificationReport[]

  @@map("deployments")
}

model VerificationReport {
  id                 String     @id @default(uuid())
  deploymentId       String
  deployment         Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  status             String     // 'healthy', 'degraded', 'offline'
  sslValid           Boolean    @default(false)
  sslIssuer          String?
  sslExpiresAt       DateTime?
  responseTimeMs     Int
  lighthousePerfScore Int       @default(0)
  screenshotUrl      String?
  consoleErrors      Json?
  ledgerSignature    String?    // Cryptographic signature of this report
  createdAt          DateTime   @default(now())

  @@map("verification_reports")
}

model Skill {
  id        String      @id @default(uuid())
  name      String      @unique
  category  String      // 'language', 'framework', 'database', 'devops'
  
  users     UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId          String
  skill            Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  proficiencyScore Int        // 0 to 100
  linesWritten     BigInt     @default(0)
  projectsCount    Int        @default(0)

  @@id([userId, skillId])
  @@map("user_skills")
}

model ProofLedger {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType          String   // 'REPOSITORY_VERIFIED', 'DEPLOYMENT_VERIFIED', 'ACHIEVEMENT_UNLOCKED'
  targetId           String   // Maps to repository_id, deployment_id, or achievement_id
  payload            Json
  cryptographicProof String
  createdAt          DateTime @default(now())

  @@map("proof_ledger")
}

model Achievement {
  id           String            @id @default(uuid())
  title        String
  description  String
  badgeIconUrl String
  criteriaType String            // 'commits_count', 'deploy_count', 'polyglot_languages'
  
  users        UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model DeveloperMetrics {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vds                   Int      @default(0)
  grade                 String   @default("Beginner Developer")
  rank                  String   @default("Beginner Developer")
  skillScore            Int      @default(0)
  contributionScore     Int      @default(0)
  trustScore            Int      @default(0)
  repositoryComplexity  Int      @default(0)
  activityScore         Int      @default(0)
  projectDiversity      Int      @default(0)
  aiAuditScore          Int      @default(0)
  commitQualityScore    Int      @default(0)
  ownershipScore        Int      @default(0)
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  @@map("developer_metrics")
}

model ContributionAnalysis {
  id                    String   @id @default(uuid())
  repositoryId          String   @unique
  repository            Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  totalCommits          Int      @default(0)
  userCommits           Int      @default(0)
  contributionPercentage Decimal @db.Decimal(5, 2) @default(0.00)
  linesAdded            Int      @default(0)
  linesDeleted          Int      @default(0)
  activeDays            Int      @default(0)
  commitConsistency     Int      @default(0)
  avgCommitsPerWeek     Decimal  @db.Decimal(5, 2) @default(0.00)
  contributionScore     Int      @default(0)
  activityScore         Int      @default(0)
  trustScore            Int      @default(0)
  ownershipScore        Int      @default(0)
  consistencyScore      Int      @default(0)
  ownershipConfidence   Int      @default(0)
  commitQualityScore    Int      @default(0)
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  @@map("contribution_analyses")
}
